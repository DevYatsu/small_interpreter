let short: "hi"
let long: "this is a long string that definitely won't fit in SSO"
print("Short:", short)
print("Long:", long)

let x: 10
spawn {
    print("Spawned Short:", short)
    print("Spawned Long:", long)
}

mut x: 10

if x > 5 {
    print(x)
} else {
    print("small")
}

while x < 20 {
    x: x + 1
}
